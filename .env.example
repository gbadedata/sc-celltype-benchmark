# Single-cell annotation pipeline configuration.
# Copy to .env and adjust values as needed.
# All variables are prefixed with SC_ to avoid collisions.

# QC thresholds
# SC_MIN_GENES_PER_CELL=200
# SC_MAX_GENES_PER_CELL=5000
# SC_MAX_PCT_MITO=20.0

# Preprocessing
# SC_N_TOP_GENES=2000
# SC_N_PCS=50
# SC_N_NEIGHBORS=15
# SC_LEIDEN_RESOLUTION=0.8

# CellTypist model
# SC_CELLTYPIST_MODEL=Immune_All_Low.pkl

# Benchmark
# SC_BENCHMARK_HOLDOUT_FRACTION=0.2
# SC_BENCHMARK_SEED=42
# SC_RANDOM_SEED=42
